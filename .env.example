# Newsletter persistence via JSONBin.io (https://jsonbin.io) — free tier
#
# These are SERVER-SIDE only variables (no VITE_ prefix).
# They are never exposed to the browser.
#
# Set them in Vercel: Project → Settings → Environment Variables
# For local dev: copy to .env.local and run `vercel dev`
#
# Setup steps:
# 1. Sign up at https://jsonbin.io (free)
# 2. Create a new Bin with initial content: {"subscribers": []}
# 3. Copy your Access Key and Bin ID below

JSONBIN_ACCESS_KEY=your_access_key_here
JSONBIN_BIN_ID=your_bin_id_here
